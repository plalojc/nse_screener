# Decision engine.
LLM_VALIDATOR=grok

# Grok/xAI API key.
XAI_API_KEY=your_xai_api_key_here

# Max top-ranked stocks to send to the LLM after local technical/news ranking.
LLM_VALIDATION_LIMIT=100

# Report preference. false = only recommended/confirmed shares.
REPORT_INCLUDE_WEAK=false

# TradingView chart id used when opening symbols from reports.
TRADINGVIEW_CHART_ID=IMppZ0T

# Optional scheduler time in IST.
SCAN_TIME_IST=08:20

# Optional: leave blank for local SQLite. Set this to migrate/run on Postgres/Supabase.
# Supabase: use Project Settings -> Database -> Connection string, not the publishable API key.
# Example: postgresql://postgres.<project-ref>:<db-password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
DB_SYSTEM_SCHEMA=system
DB_USER_SCHEMA=app_user
