# LLM validator: gemini or grok
LLM_VALIDATOR=gemini
# Max unique stocks to send to Gemini/Grok after rule-based ranking.
# Set 0 to validate every signal.
LLM_VALIDATION_LIMIT=100

# Gemini decision engine
GEMINI_VALIDATOR_API_KEY=your_gemini_api_key_here
GEMINI_VALIDATOR_MODEL=gemini-2.5-flash
GEMINI_VALIDATOR_RATE_DELAY=6.0
GEMINI_VALIDATOR_CONCURRENCY=10

# Grok batch decision engine
# Set LLM_VALIDATOR=grok to use xAI batch validation
XAI_API_KEY=your_xai_api_key_here
GROK_VALIDATOR_MODEL=grok-4.20-reasoning
GROK_VALIDATOR_BATCH_SIZE=10
GROK_VALIDATOR_MAX_RETRIES=3
GROK_VALIDATOR_BATCH_DELAY=1.0

# NSE Bhavcopy data source
NSE_BHAVCOPY_DB_PATH=nse_bhavcopy.db
NSE_BHAVCOPY_DIR=data/bhavcopy

# Optional screener settings
FILTER_ETFS=true
LOOKBACK_DAYS=365
VOLUME_SURGE_FACTOR=1.5
RSI_BREAKOUT_MIN=55
RSI_OVERBOUGHT=80
MIN_PRICE=20
MAX_PRICE=5000
MAX_OPEN_POSITIONS=10
MAX_HOLD_DAYS=21
PROFIT_TARGET_PCT=10.0
STOP_LOSS_PCT=5.0
ATR_SL_MULTIPLIER=1.5
ATR_TRAIL_MULTIPLIER=1.5
