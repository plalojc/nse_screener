# Upstox data and OAuth
DATA_SOURCE=upstox
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here
UPSTOX_CLIENT_ID=your_upstox_client_id_here
UPSTOX_CLIENT_SECRET=your_upstox_client_secret_here
UPSTOX_REDIRECT_URI=http://127.0.0.1:8765/callback

# Gemini decision engine
GEMINI_VALIDATOR_API_KEY=your_gemini_api_key_here
GEMINI_VALIDATOR_MODEL=gemini-2.5-flash
GEMINI_VALIDATOR_RATE_DELAY=6.0
GEMINI_VALIDATOR_CONCURRENCY=10

# NSE Bhavcopy alternate data source
# Set DATA_SOURCE=nse_bhavcopy to read OHLCV from https://www.nseindia.com/all-reports
NSE_BHAVCOPY_DB_PATH=nse_bhavcopy.db
NSE_BHAVCOPY_DIR=data/bhavcopy

# Optional screener settings
FILTER_ETFS=true
LOOKBACK_DAYS=365
VOLUME_SURGE_FACTOR=1.5
RSI_BREAKOUT_MIN=55
RSI_OVERBOUGHT=80
MIN_PRICE=20
MAX_PRICE=5000
MAX_OPEN_POSITIONS=10
MAX_HOLD_DAYS=21
PROFIT_TARGET_PCT=10.0
STOP_LOSS_PCT=5.0
ATR_SL_MULTIPLIER=1.5
ATR_TRAIL_MULTIPLIER=1.5
