# ── Groq LLM Panel ────────────────────────────────────────────────
# Get key at: https://console.groq.com/keys
LLM_API_KEY=gsk_your_groq_key_here
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1

# Panel agent models (paid Groq subscription)
LLM_PANEL_TECH_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_PANEL_SENT_MODEL=llama-3.1-8b-instant
LLM_PANEL_RISK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_PANEL_MODERATOR_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct

# Free-tier fallback models (if you don't have a paid Groq subscription)
# LLM_PANEL_TECH_MODEL=llama-3.3-70b-versatile
# LLM_PANEL_RISK_MODEL=llama-3.3-70b-versatile
# LLM_PANEL_MODERATOR_MODEL=llama-3.3-70b-versatile

# Panel consensus weights (must sum to 1.0)
# PANEL_TECH_WEIGHT=0.50
# PANEL_SENT_WEIGHT=0.20
# PANEL_RISK_WEIGHT=0.30

# Rate-limit mitigation
# PANEL_SEQUENTIAL_MODE=false
# PANEL_AGENT_DELAY=1.0

# ── Upstox (required for data) ────────────────────────────────────
# Generate / refresh token via: python main.py auth
# Or get manually at: https://upstox.com/developer/
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# Upstox OAuth credentials (needed for python main.py auth)
# Get credentials at: https://account.upstox.com/developer/apps
# Register redirect URI in your app settings before running auth.
UPSTOX_CLIENT_ID=your_upstox_client_id_here
UPSTOX_CLIENT_SECRET=your_upstox_client_secret_here
UPSTOX_REDIRECT_URI=http://127.0.0.1:8765/callback

# ── Gemini Direct Validator (recommended — replaces multi-LLM panel) ──
# ONE Gemini call + Google Search grounding per signal.
# When enabled, steps 4b (Gemini sentiment) and 4c (Claude live) are
# automatically skipped — Gemini already covers live news search.
# Set USE_GEMINI_VALIDATOR=true and disable the panel (USE_MULTI_LLM_PANEL=false)
# for best results.
#
# Models:
#   gemini-2.5-flash  — fast, free tier (10 RPM → use RATE_DELAY=6.0)
#   gemini-2.5-pro    — best accuracy   (Tier 1  → use RATE_DELAY=0.4)
#
# Key reuse: if GEMINI_VALIDATOR_API_KEY is not set, falls back to
# GEMINI_SENTIMENT_API_KEY automatically.
# Get key at: https://aistudio.google.com/apikey
USE_GEMINI_VALIDATOR=true
GEMINI_VALIDATOR_API_KEY=your_gemini_api_key_here
GEMINI_VALIDATOR_MODEL=gemini-2.5-flash
GEMINI_VALIDATOR_RATE_DELAY=6.0              # free tier: 10 RPM → 6s between calls
# GEMINI_VALIDATOR_MODEL=gemini-2.5-pro
# GEMINI_VALIDATOR_RATE_DELAY=0.4            # paid Tier 1
# Max concurrent async calls. Free tier (10 RPM): 10. Paid Tier 1 (150 RPM): 20-50.
GEMINI_VALIDATOR_CONCURRENCY=10

# ── Claude Live Validation (optional, post-panel Step 4c) ─────────
# Only used when USE_GEMINI_VALIDATOR=false (Multi-LLM Panel path).
# Get key at: https://console.anthropic.com/settings/keys
USE_LIVE_VALIDATION=false
LIVE_API_KEY=sk-ant-your_anthropic_key_here
LIVE_MODEL=claude-opus-4-6

# ── Gemini Sentiment Validation (optional, post-panel Step 4b) ────
# Only used when USE_GEMINI_VALIDATOR=false (Multi-LLM Panel path).
# Get key at: https://aistudio.google.com/apikey
# Free tier: 500 grounded searches/day, 10 RPM
USE_GEMINI_SENTIMENT=false
GEMINI_SENTIMENT_API_KEY=your_gemini_api_key_here
# GEMINI_SENTIMENT_MODEL=gemini-2.5-flash
# GEMINI_SENTIMENT_RATE_DELAY=1.0

# ── MarketAux News/Sentiment (optional, pluggable) ─────────────────
# Enriches the SENTIMENT agent with API-scored entity sentiment.
# Get key at: https://www.marketaux.com/account/dashboard
# Free tier: 100 req/day, 3 articles/req
USE_MARKETAUX=false
MARKETAUX_API_KEY=your_marketaux_api_key_here
# MARKETAUX_MAX_ARTICLES=3
# MARKETAUX_RATE_DELAY=0.5

# ── Screener settings (optional overrides) ────────────────────────
FILTER_ETFS=true
# RSI_OVERBOUGHT=80
# MIN_PRICE=20
# MAX_PRICE=5000
# MAX_OPEN_POSITIONS=10
# MAX_HOLD_DAYS=21
# PROFIT_TARGET_PCT=10.0
# ATR_SL_MULTIPLIER=1.5
