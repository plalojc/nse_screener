# Choose decision engine: gemini or grok
LLM_VALIDATOR=gemini

# API keys. Fill the one you use; keep the other blank.
GEMINI_VALIDATOR_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Max top-ranked stocks to send to the LLM after local technical/news ranking.
LLM_VALIDATION_LIMIT=100

# Report preference. false = only recommended/confirmed shares.
REPORT_INCLUDE_WEAK=false

# Optional scheduler time in IST.
SCAN_TIME_IST=08:20
